values_to = "valor"
) |>
mutate(valor = limpar_valor_ibge(valor), variavel = nome_var)
lista_6957 <- append(lista_6957, list(df_long))
}
censo_lavoura <- bind_rows(lista_6957) |>
pivot_wider(
id_cols     = c(cod_ibge, nome_municipio, produto),
names_from  = variavel,
