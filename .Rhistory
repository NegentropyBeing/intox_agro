View(base)
library(arrow)
library(dplyr)
library(readxl)
library(tidyr)
cat("=== Racial composition (Census 2022) ===\n")
raca_raw <- read_excel("Bancos/pop_raca_cor_2022.xlsx", sheet = 1,
skip = 6, col_names = FALSE)
names(raca_raw) <- c("cod_ibge", "nome_municipio", "idade",
"pct_branca", "pct_preta", "pct_amarela",
"pct_parda", "pct_indigena")
raca_out <- raca_raw |>
filter(grepl("^35", cod_ibge)) |>
mutate(
cod_ibge     = substr(cod_ibge, 1, 6),
pct_branca   = as.numeric(pct_branca),
pct_preta    = as.numeric(pct_preta),
pct_amarela  = as.numeric(pct_amarela),
pct_parda    = as.numeric(pct_parda),
pct_indigena = as.numeric(pct_indigena)
) |>
select(cod_ibge, pct_branca, pct_preta, pct_amarela, pct_parda, pct_indigena)
cat("Municipalities:", nrow(raca_out), "\n")
write_parquet(raca_out, "resultados/contextual/pop_raca_cor_sp_2022.parquet",
compression = "zstd")
cat("Saved: resultados/contextual/pop_raca_cor_sp_2022.parquet\n\n")
rm(raca_raw, raca_out)
cat("=== Done ===\n")
