)
cat(sprintf("T6957 final: %d linhas x %d colunas\n", nrow(censo_lavoura), ncol(censo_lavoura)))
write_parquet(censo_lavoura, "./resultados/PROD_AGRO/censo_agro_lavoura_2017.parquet",
