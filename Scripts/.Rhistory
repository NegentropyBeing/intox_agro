library(arrow)
library(dplyr)
library(readxl)
library(tidyr)
cat("=== Racial composition (Census 2022) ===\n")
raca_raw <- read_excel("Bancos/pop_raca_cor_2022.xlsx", sheet = 1,
skip = 6, col_names = FALSE)
names(raca_raw) <- c("cod_ibge", "nome_municipio", "idade",
"pct_branca", "pct_preta", "pct_amarela",
"pct_parda", "pct_indigena")
